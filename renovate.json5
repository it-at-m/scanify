{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  extends: ["config:recommended"],
  baseBranches: ["dev"],
  automerge: true,
  automergeType: "pr",
  platformAutomerge: true,
  {
  "packageRules": [
    {
      "matchManagers": ["gradle", "gradle-wrapper"],
      "enabled": false
    }
  ]
}
}
